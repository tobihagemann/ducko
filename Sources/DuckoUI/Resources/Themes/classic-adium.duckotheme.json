{
    "id": "classic-adium",
    "name": "Classic Adium",
    "author": "Ducko",
    "version": "1.0",
    "outgoingBubbleColor": { "light": "#B8E986", "dark": "#6B8F3A" },
    "incomingBubbleColor": { "light": "#F5F0E1", "dark": "#3A3530" },
    "outgoingTextColor": { "light": "#000000", "dark": "#FFFFFF" },
    "incomingTextColor": { "light": "#000000", "dark": "#FFFFFF" },
    "bubbleCornerRadius": 8,
    "bubblePadding": 10,
    "messageFont": { "size": 14, "weight": "regular" },
    "timestampFont": { "size": 10, "weight": "regular" },
    "showAvatars": true,
    "avatarSize": 28,
    "avatarShape": "roundedRect",
    "avatarPosition": "leading",
    "showStatusMessages": true,
    "showPresenceIndicators": true,
    "timestampStyle": "inline",
    "timestampFormat": null,
    "accentColor": { "light": "#6B8F3A", "dark": "#B8E986" },
    "backgroundColor": { "light": "#FAF8F3", "dark": "#2A2520" },
    "separatorColor": { "light": "#DDD8CB", "dark": "#4A4540" },
    "unreadBadgeColor": { "light": "#FF3B30", "dark": "#FF453A" },
    "showLinkPreviews": true,
    "linkPreviewStyle": "full"
}
